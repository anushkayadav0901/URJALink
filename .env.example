# Required for MVP
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
GEMINI_API_KEY=your_gemini_key_here
DEDALUS_API_KEY=""
EIA_API_KEY=""

# Optional (Phase 2)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
DO_GRADIENT_API_KEY=your_do_key
DO_GRADIENT_ENDPOINT=https://your-model.gradient.do/predict

# App Config
DEBUG=True

# CORS — comma-separated list of allowed frontend origins (defaults to localhost if unset)
# ALLOWED_ORIGINS=https://your-frontend.trycloudflare.com,http://localhost:8080
